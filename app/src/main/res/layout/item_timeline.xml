<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="20dp"
    android:layout_marginEnd="20dp"
    android:layout_marginBottom="24dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeWidth="2dp"
    app:strokeColor="#000000">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Logo Circle (Top Left) -->
        <TextView
            android:id="@+id/tvLogoCircle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:background="@drawable/circle_bg"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Service Name (Right of Logo) -->
        <TextView
            android:id="@+id/tvServiceName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/tvLogoCircle"
            android:layout_marginStart="16dp"
            android:textColor="#000000"
            android:textSize="22sp" />

        <!-- Date (Below Service Name) -->
        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvServiceName"
            android:layout_toEndOf="@id/tvLogoCircle"
            android:layout_marginStart="16dp"
            android:textColor="#9E9E9E"
            android:textSize="14sp" />

        <!-- SOON Badge (Top Right) -->
        <TextView
            android:id="@+id/cvSoonBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:background="@drawable/badge_soon"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="SOON"
            android:textColor="#D32F2F"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Days Away (Bottom Left) -->
        <TextView
            android:id="@+id/tvDaysAway"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvLogoCircle"
            android:layout_alignParentStart="true"
            android:layout_marginTop="32dp"
            android:textColor="#9E9E9E"
            android:textSize="14sp" />

        <!-- Price (Bottom Right) -->
        <TextView
            android:id="@+id/tvPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignBottom="@id/tvDaysAway"
            android:textColor="#000000"
            android:textSize="24sp"
            android:textStyle="bold" />

    </RelativeLayout>
</com.google.android.material.card.MaterialCardView>