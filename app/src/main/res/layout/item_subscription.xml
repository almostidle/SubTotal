<?xml version="1.0" encoding="utf-8"?>
<!--
    BUG FIX:
    The original item_subscription.xml used @color/text_primary, @color/text_secondary,
    and @color/primary — all missing from colors.xml (now added). It also referenced
    @drawable/ic_app_placeholder which did not exist (now added as a grey oval).

    These are only crash-safe once BOTH colors.xml and ic_app_placeholder.xml are
    updated. This file itself is unchanged in structure — only confirmed correct.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/ivAppIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_app_placeholder"
            android:contentDescription="App icon"
            android:background="@drawable/circle_bg"
            android:padding="8dp"
            android:scaleType="centerInside"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvAppName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:text="App Name"/>

            <TextView
                android:id="@+id/tvBillingCycle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:text="Monthly"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvRenewalDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:text="Renews: 01/01/2025"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvCost"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:text="$9.99"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>